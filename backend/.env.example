# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jukebox"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"

# App
PORT=3000
FRONTEND_URL="http://localhost:8000"
# For multiple origins (production): FRONTEND_URL="https://yourdomain.com,https://www.yourdomain.com"

# AcoustID fingerprinting (https://acoustid.org/api-key)
ACOUSTID_API_KEY=""
FPCALC_PATH="fpcalc"
# On Linux: FPCALC_PATH="/usr/bin/fpcalc"

# Periodic ingest
# Set INGEST_USER_ID to the UUID of your admin user account to enable automatic ingestion.
# Leave commented out to disable.
# INGEST_USER_ID=""
INGEST_WATCH_DIR="uploads/songs"
INGEST_INTERVAL_MINUTES=2
INGEST_MIN_AGE_SECONDS=30
INGEST_ACOUSTID_DELAY_MS=400
